@startuml
title Package di analisi (Reale) - Smart Home

skinparam shadowing false
skinparam packageStyle rectangle
left to right direction

package "pkg Package di analisi" {
  package "Dispositivi" as PKG_DEV {
    class Device
    class Room
  }

  package "Automazioni" as PKG_AUT {
    class Automation
  }

  package "Eventi" as PKG_EVT {
    class Event
    class EventLog
  }

  package "Utenti" as PKG_USR {
    class User
  }

  package "Sistema" as PKG_SYS {
    class SmartHomeSystem
  }
}

PKG_DEV ..> PKG_AUT : <<use>>
PKG_AUT ..> PKG_DEV : <<use>>
PKG_AUT ..> PKG_EVT : <<use>>
PKG_SYS ..> PKG_DEV : <<use>>
PKG_SYS ..> PKG_AUT : <<use>>
PKG_SYS ..> PKG_EVT : <<use>>
PKG_SYS ..> PKG_USR : <<use>>
PKG_USR ..> PKG_SYS : <<use>>

newpage
title Package di analisi: Dispositivi

package "class Dispositivi" {
  class Room {
    +id: UUID
    +name: string
    +devices: list
    +addDevice(device)
    +removeDevice(device)
    +getDevices()
  }

  class Device {
    +id: UUID
    +name: string
    +state: boolean
    +value: float
    +unit: string
    +energyConsumption: float
    +turnOn()
    +turnOff()
    +setValue(value)
    +getState()
    +getValue()
  }
}

Room "1" --> "0..*" Device : contiene

newpage
title Package di analisi: Automazioni

package "class Automazioni" {
  class Automation {
    +id: UUID
    +name: string
    +active: boolean
    +schedule: datetime
    +condition: string
    +action: string
    +activate()
    +deactivate()
    +checkCondition()
    +execute()
  }
}

Automation "1" --> "0..*" Device : controlla

newpage
title Package di analisi: Eventi

package "class Eventi" {
  class Event {
    +id: UUID
    +timestamp: datetime
    +type: string
    +description: string
    +source: string
  }

  class EventLog {
    +events: list
    +addEvent(event)
    +getEvents()
    +filterByDate(date)
    +filterByType(type)
  }
}

EventLog "1" --> "0..*" Event : memorizza
Event ..> Device : origine
Event ..> Automation : origine

newpage
title Package di analisi: Utenti e Sistema

package "class Utenti e Sistema" {
  class User {
    +id: UUID
    +username: string
    +password: string
    +email: string
    +role: string
    +login()
    +logout()
    +updateProfile()
    +accessDashboard()
  }

  class SmartHomeSystem {
    +controlDevice(device)
    +executeAutomation(automation)
    +executeAutomations()
    +generateEvent(type, description)
    +getSystemStatus()
  }
}

User --> SmartHomeSystem : usa
SmartHomeSystem --> Device : gestisce
SmartHomeSystem --> Room : gestisce
SmartHomeSystem --> Automation : gestisce
SmartHomeSystem --> EventLog : usa

@enduml
