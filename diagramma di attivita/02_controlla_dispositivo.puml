@startuml
title Controlla Dispositivo

start

:Login utente;
:Verifica credenziali;

if (Credenziali valide?) then (si)
  :Accesso dashboard;
else (no)
  :Genera evento login fallito;
  :Memorizza evento;
  stop
endif

:Ricerca stanza;
:Ricerca dispositivo;

if (Accensione?) then (si)
  :Accende dispositivo;
else (no)
  if (Spegnimento?) then (si)
    :Spegne dispositivo;
  else (aggiorna valore)
    :Inserisci nuovo valore;
    :Aggiorna valore dispositivo;
  endif
endif

:Genera evento dispositivo;
:Memorizza evento;
:Visualizza stato aggiornato;

stop
@enduml
